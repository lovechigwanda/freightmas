 "font_size": 12,
 "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<style>\nbody { font-family: Arial, sans-serif; color: #111; font-size: 12px; }\n.print-page { padding: 18px; }\n.header { border-bottom: 2px solid #111; padding-bottom: 10px; margin-bottom: 18px; }\n.company { font-size: 20px; font-weight: 700; }\n.title { font-size: 16px; font-weight: 700; margin-top: 4px; }\n.meta-grid { width: 100%; border-collapse: collapse; margin-bottom: 16px; }\n.meta-grid td { padding: 5px 6px; vertical-align: top; }\n.label { font-weight: 700; width: 18%; color: #333; }\n.value { width: 32%; }\n.balance-table { width: 100%; border-collapse: collapse; margin: 12px 0 18px; }\n.balance-table th, .balance-table td { border: 1px solid #333; padding: 8px; }\n.balance-table th { background: #f2f2f2; text-align: left; }\n.amount { text-align: right; white-space: nowrap; }\n.status { font-weight: 700; }\n.remarks { border: 1px solid #333; min-height: 70px; padding: 8px; margin-top: 6px; }\n.signatures { width: 100%; margin-top: 42px; border-collapse: collapse; }\n.signatures td { width: 33.33%; padding: 0 14px; text-align: center; }\n.sig-line { border-top: 1px solid #111; padding-top: 6px; }\n.footer { margin-top: 24px; font-size: 10px; color: #555; }\n</style>\n</head>\n<body>\n<div class=\"print-page\">\n<div class=\"header\">\n<div class=\"company\">{{ doc.company }}</div>\n<div class=\"title\">Cash Reconciliation</div>\n</div>\n<table class=\"meta-grid\">\n<tr><td class=\"label\">Reference</td><td class=\"value\">{{ doc.name }}</td><td class=\"label\">Status</td><td class=\"value status\">{{ doc.reconciliation_status or '' }}</td></tr>\n<tr><td class=\"label\">Date</td><td class=\"value\">{{ frappe.utils.formatdate(doc.posting_date, 'dd-MMM-yyyy') }} {{ doc.posting_time or '' }}</td><td class=\"label\">Cashier</td><td class=\"value\">{{ doc.cashier or '' }}</td></tr>\n<tr><td class=\"label\">Branch / Station</td><td class=\"value\">{{ doc.branch or '' }}</td><td class=\"label\">Cash Account</td><td class=\"value\">{{ doc.cash_account or '' }}</td></tr>\n<tr><td class=\"label\">Fetched On</td><td class=\"value\">{{ frappe.utils.format_datetime(doc.fetched_on) if doc.fetched_on else '' }}</td><td class=\"label\">Approved By</td><td class=\"value\">{{ doc.approved_by or '' }}</td></tr>\n</table>\n<table class=\"balance-table\">\n<thead><tr><th>Balance Type</th><th class=\"amount\">Amount</th></tr></thead>\n<tbody>\n<tr><td>Ledger Balance</td><td class=\"amount\">{{ frappe.utils.fmt_money(doc.ledger_balance, currency=doc.company_currency) }}</td></tr>\n<tr><td>Physical Cash Balance</td><td class=\"amount\">{{ frappe.utils.fmt_money(doc.physical_cash_balance, currency=doc.company_currency) }}</td></tr>\n<tr><td><strong>Difference</strong></td><td class=\"amount\"><strong>{{ frappe.utils.fmt_money(doc.difference, currency=doc.company_currency) }}</strong></td></tr>\n</tbody>\n</table>\n<div><strong>Remarks</strong></div>\n<div class=\"remarks\">{{ doc.remarks or '' }}</div>\n<table class=\"signatures\">\n<tr><td><div class=\"sig-line\">Prepared By</div></td><td><div class=\"sig-line\">Checked By</div></td><td><div class=\"sig-line\">Approved By</div></td></tr>\n</table>\n<div class=\"footer\">Printed on {{ frappe.utils.format_datetime(frappe.utils.now_datetime()) }}</div>\n</div>\n</body>\n</html>",
