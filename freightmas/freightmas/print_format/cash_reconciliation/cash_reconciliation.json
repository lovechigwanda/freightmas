 "font_size": 12,
 "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<style>\nbody { font-family: Arial, sans-serif; color: #111; font-size: 12px; }\n.print-page { padding: 18px; }\n.header { border-bottom: 2px solid #111; padding-bottom: 10px; margin-bottom: 18px; }\n.company { font-size: 20px; font-weight: 700; }\n.title { font-size: 16px; font-weight: 700; margin-top: 4px; }\n.meta-grid { width: 100%; border-collapse: collapse; margin-bottom: 16px; }\n.meta-grid td { padding: 5px 6px; vertical-align: top; }\n.label { font-weight: 700; width: 18%; color: #333; }\n.value { width: 32%; }\n.section-heading { font-weight: 700; font-size: 12px; margin: 16px 0 6px; }\n.section-sub { font-weight: normal; margin-left: 10px; color: #444; }\n.balance-table { width: 100%; border-collapse: collapse; margin: 0 0 16px; }\n.balance-table th, .balance-table td { border: 1px solid #333; padding: 8px; }\n.balance-table th { background: #f2f2f2; text-align: left; }\n.amount { text-align: right; white-space: nowrap; }\n.status { font-weight: 700; }\n.remarks-box { border: 1px solid #333; min-height: 60px; padding: 8px; margin-top: 6px; margin-bottom: 18px; }\n.signatures { width: 100%; margin-top: 42px; border-collapse: collapse; }\n.signatures td { width: 33.33%; padding: 0 14px; text-align: center; }\n.sig-line { border-top: 1px solid #111; padding-top: 6px; }\n.footer { margin-top: 24px; font-size: 10px; color: #555; }\n</style>\n</head>\n<body>\n<div class=\"print-page\">\n\n<div class=\"header\">\n  <div class=\"company\">{{ doc.company }}</div>\n  <div class=\"title\">Cash Reconciliation</div>\n</div>\n\n<table class=\"meta-grid\">\n  <tr>\n    <td class=\"label\">Reference</td>\n    <td class=\"value\">{{ doc.name }}</td>\n    <td class=\"label\">Status</td>\n    <td class=\"value status\">{{ doc.reconciliation_status or '' }}</td>\n  </tr>\n  <tr>\n    <td class=\"label\">Date</td>\n    <td class=\"value\">{{ frappe.utils.formatdate(doc.posting_date, 'dd-MMM-yyyy') }} {{ doc.posting_time or '' }}</td>\n    <td class=\"label\">Cashier</td>\n    <td class=\"value\">{{ doc.cashier or '' }}</td>\n  </tr>\n  <tr>\n    <td class=\"label\">Branch / Station</td>\n    <td class=\"value\">{{ doc.branch or '' }}</td>\n    <td class=\"label\">Cash Account</td>\n    <td class=\"value\">{{ doc.cash_account or '' }}</td>\n  </tr>\n  <tr>\n    <td class=\"label\">Approved By</td>\n    <td class=\"value\">{{ doc.approved_by or '' }}</td>\n    <td class=\"label\">Approved On</td>\n    <td class=\"value\">{{ frappe.utils.format_datetime(doc.approved_on) if doc.approved_on else '' }}</td>\n  </tr>\n</table>\n\n<div class=\"section-heading\">Balances</div>\n<table class=\"balance-table\">\n  <thead><tr><th>Balance Type</th><th class=\"amount\">Amount ({{ doc.company_currency or '' }})</th></tr></thead>\n  <tbody>\n    <tr>\n      <td>Ledger Balance</td>\n      <td class=\"amount\">{{ frappe.utils.fmt_money(doc.ledger_balance or 0, currency=doc.company_currency) }}</td>\n    </tr>\n    <tr>\n      <td>Physical Cash Balance</td>\n      <td class=\"amount\">{{ frappe.utils.fmt_money(doc.physical_cash_balance or 0, currency=doc.company_currency) }}</td>\n    </tr>\n    <tr>\n      <td><strong>Difference</strong></td>\n      <td class=\"amount\"><strong>{{ frappe.utils.fmt_money(doc.difference or 0, currency=doc.company_currency) }}</strong></td>\n    </tr>\n  </tbody>\n</table>\n\n{% if doc.period_from %}\n<div class=\"section-heading\">Period Flow Analysis\n  <span class=\"section-sub\">{{ doc.period_type or 'Day' }}: {{ frappe.utils.formatdate(doc.period_from, 'dd-MMM-yyyy') }}{% if doc.period_to %} \u2013 {{ frappe.utils.formatdate(doc.period_to, 'dd-MMM-yyyy') }}{% endif %}</span>\n</div>\n<table class=\"balance-table\">\n  <thead><tr><th>Flow</th><th class=\"amount\">Amount ({{ doc.company_currency or '' }})</th></tr></thead>\n  <tbody>\n    <tr>\n      <td>Period Receipts (Debits)</td>\n      <td class=\"amount\">{{ frappe.utils.fmt_money(doc.period_receipts or 0, currency=doc.company_currency) }}</td>\n    </tr>\n    <tr>\n      <td>Period Payments (Credits)</td>\n      <td class=\"amount\">{{ frappe.utils.fmt_money(doc.period_payments or 0, currency=doc.company_currency) }}</td>\n    </tr>\n    <tr>\n      <td><strong>Period Net Flow</strong></td>\n      <td class=\"amount\"><strong>{{ frappe.utils.fmt_money(doc.period_net_flow or 0, currency=doc.company_currency) }}</strong></td>\n    </tr>\n  </tbody>\n</table>\n{% endif %}\n\n<div class=\"section-heading\">Remarks</div>\n<div class=\"remarks-box\">{{ doc.remarks or '' }}</div>\n\n<table class=\"signatures\">\n  <tr>\n    <td><div class=\"sig-line\">Prepared By</div></td>\n    <td><div class=\"sig-line\">Checked By</div></td>\n    <td><div class=\"sig-line\">Approved By</div></td>\n  </tr>\n</table>\n\n<div class=\"footer\">Printed on {{ frappe.utils.format_datetime(frappe.utils.now_datetime()) }}</div>\n</div>\n</body>\n</html>",
