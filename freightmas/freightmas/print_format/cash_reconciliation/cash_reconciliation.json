 "html": "{%- set no_default_print_heading = 1 -%}\n{%- from \"templates/print_formats/standard_macros.html\" import add_header -%}\n\n<div class=\"main-container\">\n  {{ add_header(0, 1, doc, letter_head, no_letterhead, print_settings) }}\n\n  <style>\n  {%- set border_inset = 0 -%}\n  {%- set content_inner_padding = 3 -%}\n  html, body { margin:0; padding:0; height:100%; font-family: Arial, sans-serif; font-size: 13px; }\n  .page-border { position:fixed; top:{{ border_inset }}mm; left:{{ border_inset }}mm; right:{{ border_inset }}mm; bottom:{{ border_inset }}mm; border:1px solid #000; z-index:0; pointer-events:none; }\n  .main-container { position:relative; z-index:1; padding:{{ content_inner_padding }}mm; font-family: Arial, sans-serif; font-size: 13px; }\n  .heading-label { font-size:18px; font-weight:600; text-align:center; color:#222; margin-bottom:4px; letter-spacing:1px; text-transform:uppercase; }\n  .section { margin-bottom:6px; }\n  .section-title { font-size:13px; font-weight:600; border-bottom:1px solid #000; margin-bottom:4px; padding-bottom:2px; }\n  .info-table, .summary-table { width:100%; border-collapse:collapse; }\n  .info-table td, .summary-table td { padding:3px 0; vertical-align:top; font-size:13px; }\n  .info-table .label { width:18%; font-weight:600; color:#333; }\n  .info-value { width:32%; }\n  .summary-table td { padding:4px 6px; border-bottom:1px solid #f0f3f5; }\n  .summary-table th { text-align:left; padding:4px 6px; border-bottom:1px solid #000; font-weight:700; }\n  .rt { text-align:right; }\n  .remarks-box { border:1px solid #333; min-height:60px; padding:8px; margin-top:6px; }\n  .signatures { width:100%; margin-top:24px; border-collapse:collapse; }\n  .signatures td { width:33.33%; padding:0 14px; text-align:center; }\n  .sig-line { border-top:1px solid #111; padding-top:6px; }\n  .footer { margin-top:16px; font-size:10px; color:#555; text-align:center; }\n  </style>\n\n  <div class=\"page-border\"></div>\n\n  <div class=\"heading-label\">Cash Reconciliation</div>\n\n  <div class=\"section\">\n    <table class=\"info-table\">\n      <tr>\n        <td class=\"label\">Reference</td>\n        <td class=\"info-value\"><strong>{{ doc.name }}</strong></td>\n        <td class=\"label\">Status</td>\n        <td class=\"info-value\"><strong>{{ doc.reconciliation_status or '' }}</strong></td>\n      </tr>\n      <tr>\n        <td class=\"label\">Date</td>\n        <td class=\"info-value\">{{ frappe.utils.formatdate(doc.posting_date, 'dd-MMM-yyyy') }} {{ doc.posting_time or '' }}</td>\n        <td class=\"label\">Cashier</td>\n        <td class=\"info-value\">{{ doc.cashier or '' }}</td>\n      </tr>\n      <tr>\n        <td class=\"label\">Branch / Station</td>\n        <td class=\"info-value\">{{ doc.branch or '' }}</td>\n        <td class=\"label\">Cash Account</td>\n        <td class=\"info-value\">{{ doc.cash_account or '' }}</td>\n      </tr>\n      <tr>\n        <td class=\"label\">Approved By</td>\n        <td class=\"info-value\">{{ doc.approved_by or '' }}</td>\n        <td class=\"label\">Approved On</td>\n        <td class=\"info-value\">{{ frappe.utils.format_datetime(doc.approved_on) if doc.approved_on else '' }}</td>\n      </tr>\n    </table>\n  </div>\n\n  <div class=\"section\">\n    <div class=\"section-title\">Balances</div>\n    <table class=\"summary-table\">\n      <tbody>\n        <tr>\n          <td>Ledger Balance</td>\n          <td class=\"rt\">{{ frappe.utils.fmt_money(doc.ledger_balance or 0, currency=doc.company_currency) }}</td>\n        </tr>\n        <tr>\n          <td>Physical Cash Balance</td>\n          <td class=\"rt\">{{ frappe.utils.fmt_money(doc.physical_cash_balance or 0, currency=doc.company_currency) }}</td>\n        </tr>\n        <tr>\n          <td><strong>Difference</strong></td>\n          <td class=\"rt\"><strong>{{ frappe.utils.fmt_money(doc.difference or 0, currency=doc.company_currency) }}</strong></td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n\n  {% if doc.period_from %}\n  <div class=\"section\">\n    <div class=\"section-title\">Period Flow Analysis</div>\n    <table class=\"info-table\">\n      <tr>\n        <td class=\"label\">Period</td>\n        <td class=\"info-value\">{{ doc.period_type or 'Day' }}</td>\n        <td class=\"label\">From</td>\n        <td class=\"info-value\">{{ frappe.utils.formatdate(doc.period_from, 'dd-MMM-yyyy') }}</td>\n      </tr>\n      <tr>\n        <td class=\"label\">To</td>\n        <td class=\"info-value\">{{ frappe.utils.formatdate(doc.period_to, 'dd-MMM-yyyy') if doc.period_to else '' }}</td>\n        <td class=\"label\">Net Flow</td>\n        <td class=\"info-value\">{{ frappe.utils.fmt_money(doc.period_net_flow or 0, currency=doc.company_currency) }}</td>\n      </tr>\n    </table>\n    <table class=\"summary-table\" style=\"margin-top: 6px;\">\n      <tbody>\n        <tr>\n          <td>Period Receipts (Debits)</td>\n          <td class=\"rt\">{{ frappe.utils.fmt_money(doc.period_receipts or 0, currency=doc.company_currency) }}</td>\n        </tr>\n        <tr>\n          <td>Period Payments (Credits)</td>\n          <td class=\"rt\">{{ frappe.utils.fmt_money(doc.period_payments or 0, currency=doc.company_currency) }}</td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n  {% endif %}\n\n  <div class=\"section\">\n    <div class=\"section-title\">Remarks</div>\n    <div class=\"remarks-box\">{{ doc.remarks or '' }}</div>\n  </div>\n\n  <div class=\"section\">\n    <table class=\"signatures\">\n      <tr>\n        <td><div class=\"sig-line\">Prepared By</div></td>\n        <td><div class=\"sig-line\">Checked By</div></td>\n        <td><div class=\"sig-line\">Approved By</div></td>\n      </tr>\n    </table>\n  </div>\n\n  <div class=\"footer\">Printed on {{ frappe.utils.format_datetime(frappe.utils.now_datetime()) }}</div>\n</div>",
